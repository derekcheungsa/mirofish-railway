# MiroFish Environment Variables

# ============================================
# LLM Configuration (OpenRouter recommended)
# ============================================

# OpenRouter API Key (get from https://openrouter.ai/keys)
LLM_API_KEY=your_openrouter_api_key_here

# OpenRouter Base URL
LLM_BASE_URL=https://openrouter.ai/api/v1

# Model name (e.g., gpt-4o-mini, anthropic/claude-sonnet-4, deepseek/deepseek-chat-v3-0324)
LLM_MODEL_NAME=gpt-4o-mini

# ============================================
# Zep Cloud (Agent Memory)
# ============================================
# Get your API key from https://console.zep.cloud/

ZEP_API_KEY=your_zep_api_key_here

# ============================================
# MiroFish Application
# ============================================

# Flask secret key (change this to a random string)
SECRET_KEY=change-me-in-production

# Backend server port (default: 5001)
BACKEND_PORT=5001

# Frontend port (default: 3000)
FRONTEND_PORT=3000
